{
	"manifest_version": 2.0,
	"id": "portdetail",
	"type": "widget",
	"name": "Switch Port Detail",
	"namespace": "PortDetail",
	"version": "2.8",
	"author": "Custom",
	"description": "Displays detailed stats for a selected switch port. Set Override host to the Switch Port Status widget.",
	"widget": {
		"js_class": "WidgetPortDetail",
		"size": {
			"width": 12,
			"height": 4
		},
		"out": [
			{
				"type": "_itemid"
			},
			{
				"type": "_itemids"
			}
		],
		"in": {
			"time_period": {
				"type": "_timeperiod"
			}
		}
	},
	"actions": {
		"widget.portdetail.view": {
			"class": "WidgetView"
		},
		"widget.portdetail.cyclepoe": {
			"class": "CyclePoe",
			"view": "layout.json"
		}
	},
	"assets": {
		"js": [
			"class.widget.js"
		],
		"css": [
			"widget.css"
		]
	}
}
